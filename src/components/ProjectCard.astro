---
interface Props {
  title: string;
  stack: string[];
  summary: string;
  github?: string;
}

const { title, stack, summary, github } = Astro.props;
---

<div class="border border-slate-800 rounded-lg p-5 hover:border-slate-600 transition-colors">
  <div class="flex items-start justify-between gap-3">
    <h3 class="font-semibold text-slate-100">{title}</h3>
    {github && (
      <a
        href={github}
        target="_blank"
        rel="noopener noreferrer"
        class="text-xs text-slate-400 hover:text-slate-100 shrink-0"
      >
        GitHub &rarr;
      </a>
    )}
  </div>
  <p class="text-sm text-slate-400 mt-2 leading-relaxed">{summary}</p>
  <div class="flex flex-wrap gap-2 mt-4">
    {stack.map((tech) => (
      <span class="text-xs bg-slate-800 text-slate-300 rounded px-2 py-1">
        {tech}
      </span>
    ))}
  </div>
</div>
