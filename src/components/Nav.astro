---
import { profile } from '../data/profile';
import ThemeToggle from './ThemeToggle.astro';
---

<header class="border-b border-slate-800">
  <nav class="w-full max-w-4xl mx-auto px-6 py-4 flex items-center justify-between">
    <a href="/" class="font-semibold tracking-tight text-slate-100 hover:text-slate-300">
      {profile.name}
    </a>
    <div class="flex items-center gap-6 text-sm text-slate-400">
      <a href="/#about" class="hover:text-slate-100">About</a>
      <a href="/projects" class="hover:text-slate-100">Projects</a>
      <a href="/#contact" class="hover:text-slate-100">Contact</a>
      <ThemeToggle />
    </div>
  </nav>
</header>
